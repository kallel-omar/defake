{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - DeFake{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4">Admin Dashboard</h1>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card bg-dark text-white border-secondary">
                <div class="card-body">
                    <h5 class="card-title">Total Analyses</h5>
                    <p class="display-5">{{ totalChecks }}</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card bg-dark text-white border-secondary">
                <div class="card-body">
                    <h5 class="card-title">Total Users</h5>
                    <p class="display-5">{{ totalUsers }}</p>
                </div>
            </div>
        </div>
    </div>

    <h2 class="mb-3">Latest Checks</h2>

    <div class="table-responsive">
        <table class="table table-dark table-striped table-bordered align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>URL</th>
                    <th>Status</th>
                    <th>Score</th>
                    <th>Verdict</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for check in latestChecks %}
                    <tr>
                        <td>{{ check.id }}</td>
                        <td>
    {% if check.user %}
        {{ check.user.email }}
    {% else %}
        <span class="text">Guest</span>
    {% endif %}
</td>
                        <td>
                            <a href="{{ check.url }}" target="_blank" class="text-info">
                                {{ check.url|slice(0, 60) }}...
                            </a>
                        </td>
                        <td>{{ check.status }}</td>
                        <td>{{ check.score ?? '-' }}</td>
                        <td>{{ check.verdict ?? '-' }}</td>
                        <td>{{ check.createdAt ? check.createdAt|date('Y-m-d H:i') : '-' }}</td>
                        <td>
                        <a href="{{ path('app_admin_check_show', { id: check.id }) }}" class="btn btn-sm btn-info">
    Details
</a>
    <form
        method="post"
        action="{{ path('app_admin_check_delete', { id: check.id }) }}"
        onsubmit="return confirm('Are you sure you want to delete this search?');"
    >
        <input type="hidden" name="_token" value="{{ csrf_token('delete_check_' ~ check.id) }}">

        <button class="btn btn-sm btn-danger">
            Delete
        </button>
    </form>
</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center">No checks found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}