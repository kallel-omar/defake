<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}DeFake{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>

<body class="bg-light d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
    <div class="container">

        <a class="navbar-brand fw-bold d-flex align-items-center"
           href="{{ path('app_home') }}">
            <span class="fs-4">DeFake</span>

            <sup class="ms-2">
                <span class="badge rounded-pill bg-danger px-2 py-1"
                      style="font-size: 0.65rem;">
                    Beta
                </span>
            </sup>
        </a>

        <div class="d-flex align-items-center gap-2">

            {% if app.user %}

                <a href="{{ path('app_history') }}"
                   class="btn btn-outline-light btn-sm rounded-pill px-3">
                    History
                </a>

                 {% if is_granted('ROLE_ADMIN') %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_admin') }}">Admin</a>
                </li>
                {% endif %}

                <a href="{{ path('app_logout') }}"
                   class="btn btn-outline-light btn-sm rounded-pill px-3">
                    Logout
                </a>

            {% else %}

                <a href="{{ path('app_login') }}"
                   class="btn btn-outline-light btn-sm rounded-pill px-3">
                    Login
                </a>

                <a href="{{ path('app_register') }}"
                   class="btn btn-danger btn-sm rounded-pill px-3">
                    Sign Up
                </a>

            {% endif %}

        </div>

    </div>
</nav>

<div class="container mt-3">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            {% set alertClass = label == 'error' ? 'danger' : label %}

            <div class="alert alert-{{ alertClass }} alert-dismissible fade show shadow-sm border-0 rounded-4" role="alert">
                {{ message }}

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close">
                </button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

<main class="flex-grow-1">
    {% block body %}{% endblock %}
</main>

<footer class="py-4 mt-auto border-top bg-white">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 text-muted small">
        <div>
            <strong>DeFake Beta</strong> • AI-generated credibility analysis
        </div>

        <div>
            Verify important information independently.
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>