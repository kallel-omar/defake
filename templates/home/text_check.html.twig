{% extends 'base.html.twig' %}

{% block title %}Text Claim Check - DeFake{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="mb-4">
                <a href="{{ path('app_facebook_check') }}" class="text-decoration-none">
                    &larr; Check a Facebook URL instead
                </a>
            </div>

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4 p-md-5">

                    <span class="badge bg-danger rounded-pill px-3 py-2 mb-3">
                        New
                    </span>

                    <h1 class="fw-bold mb-2">Check a Text Claim</h1>

                    <p class="text-muted mb-4">
                        Paste a public claim, rumor, or news paragraph. DeFake will extract the verifiable claim,
                        search for evidence, and generate a credibility report.
                    </p>

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger">
                            {{ message }}
                        </div>
                    {% endfor %}

                    {% for message in app.flashes('info') %}
                        <div class="alert alert-info">
                            {{ message }}
                        </div>
                    {% endfor %}

                    {% if not aiAnalysisAvailable %}
                        <div class="alert alert-warning">
                            {{ aiUnavailableMessage }}
                        </div>
                    {% endif %}

                    <form method="post" action="{{ path('app_text_check') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('text_check') }}">

                        <div class="mb-3">
                            <label for="claim_text" class="form-label fw-semibold">
                                Claim or news text
                            </label>

                            <textarea
                                id="claim_text"
                                name="claim_text"
                                class="form-control rounded-4"
                                rows="7"
                                minlength="8"
                                maxlength="5000"
                                required
                                placeholder="Example: Barack Obama died."></textarea>

                            <div class="form-text">
                                Use 1 clear claim or a short news paragraph. Avoid private information.
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label for="context_country" class="form-label fw-semibold">
                                    Country or region <span class="text-muted fw-normal">(optional)</span>
                                </label>

                                <select
                                    id="context_country"
                                    name="context_country"
                                    class="form-select rounded-4">
                                    {% for countryCode, countryLabel in countryOptions %}
                                        <option value="{{ countryCode }}">{{ countryLabel }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label for="context_topic" class="form-label fw-semibold">
                                    Topic <span class="text-muted fw-normal">(optional)</span>
                                </label>

                                <select
                                    id="context_topic"
                                    name="context_topic"
                                    class="form-select rounded-4">
                                    <option value="">Not sure</option>
                                    <option value="sports">Sports</option>
                                    <option value="politics">Politics</option>
                                    <option value="health">Health</option>
                                    <option value="business">Business</option>
                                    <option value="technology">Technology</option>
                                    <option value="legal">Legal</option>
                                    <option value="weather">Weather</option>
                                    <option value="entertainment">Entertainment</option>
                                </select>
                            </div>
                        </div>

                        <button
                            type="submit"
                            class="btn btn-danger rounded-pill px-4 py-2"
                            {% if not aiAnalysisAvailable %}disabled{% endif %}>
                            Check Text Claim
                        </button>
                    </form>
                </div>
            </div>

            <div class="alert alert-warning mt-4 rounded-4">
                DeFake is a beta credibility tool. It may make mistakes and should not replace professional fact-checking.
            </div>

        </div>
    </div>
</div>
{% endblock %}
