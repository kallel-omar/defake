{% extends 'base.html.twig' %}

{% block title %}DeFake - Fake News Detection{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="text-center mb-5">

                <span class="badge bg-danger mb-3 px-3 py-2">
                    Public Beta
                </span>

                <h1 class="display-3 fw-bold">
                    DeFake
                </h1>

                <p class="lead text-muted mb-2">
                    Analyze public claims, rumors, social media posts, articles and online content
                    to detect misinformation and fake news.
                </p>

                <div class="small text-muted">
                    &#128679; AI-generated credibility analysis &middot; Verify important information independently
                </div>

            </div>

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger">
                            {{ message }}
                        </div>
                    {% endfor %}

                    {% for message in app.flashes('info') %}
                        <div class="alert alert-info">
                            {{ message }}
                        </div>
                    {% endfor %}

                    {% if not aiAnalysisAvailable %}
                        <div class="alert alert-warning">
                            {{ aiUnavailableMessage }}
                        </div>
                    {% endif %}

                    <form method="post" action="{{ path('app_text_check') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('text_check') }}">

                        <div class="mb-4">
                            <label for="claim_text" class="form-label fw-semibold">
                                Paste a claim or news text
                            </label>

                            <textarea
                                id="claim_text"
                                name="claim_text"
                                class="form-control form-control-lg rounded-4"
                                rows="7"
                                minlength="8"
                                maxlength="5000"
                                required
                                placeholder="Example: Yann Sasse the Esperance Sportive player died."></textarea>

                            <div class="form-text">
                                Works with football rumors, public figures, transfers, injuries, deaths, dates, numbers, sanctions and official announcements.
                            </div>
                        </div>

                        <button
                            type="submit"
                            class="btn btn-danger btn-lg w-100 rounded-pill"
                            {% if not aiAnalysisAvailable %}disabled{% endif %}>
                            &#128269; Analyze Claim
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a href="{{ path('app_facebook_check') }}" class="btn btn-outline-dark rounded-pill px-4">
                            Check a Facebook post URL instead
                        </a>
                    </div>

                </div>
            </div>

            <div class="row text-center mt-5">

                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h3>&#9889;</h3>
                            <h5>Fast Analysis</h5>
                            <p class="text-muted small">
                                Get credibility results within seconds.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h3>&#129302;</h3>
                            <h5>AI Review</h5>
                            <p class="text-muted small">
                                AI extracts claims and evaluates evidence, sources and language.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h3>&#128202;</h3>
                            <h5>Detailed Report</h5>
                            <p class="text-muted small">
                                View score, verdict, evidence and explanation.
                            </p>
                        </div>
                    </div>
                </div>

            </div>

            <p class="text-center text-muted small mt-4 mb-0">
                DeFake is a beta tool. Results may contain errors and should not replace professional fact-checking.
            </p>

        </div>
    </div>

</div>
{% endblock %}
