{% extends 'base.html.twig' %}

{% block title %}Create Account - DeFake{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">

            <div class="text-center mb-4">
                <span class="badge bg-danger rounded-pill px-3 py-2 mb-3">
                    DeFake Beta
                </span>

                <h1 class="fw-bold mb-2">Create your account</h1>

                <p class="text-muted mb-0">
                    Register to save your analysis history and unlock higher daily limits.
                </p>
            </div>

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4 p-md-5">

                    {{ form_errors(registrationForm) }}

                    {{ form_start(registrationForm) }}

                        <div class="mb-3">
                            {{ form_label(registrationForm.email, 'Email address', {
                                label_attr: {
                                    class: 'form-label fw-semibold'
                                }
                            }) }}

                            {{ form_widget(registrationForm.email, {
                                attr: {
                                    class: 'form-control form-control-lg rounded-3',
                                    placeholder: 'you@example.com'
                                }
                            }) }}

                            {{ form_errors(registrationForm.email) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword, 'Password', {
                                label_attr: {
                                    class: 'form-label fw-semibold'
                                }
                            }) }}

                            {{ form_widget(registrationForm.plainPassword, {
                                attr: {
                                    class: 'form-control form-control-lg rounded-3',
                                    placeholder: 'Choose a strong password'
                                }
                            }) }}

                            {{ form_errors(registrationForm.plainPassword) }}
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                {{ form_widget(registrationForm.agreeTerms, {
                                    attr: {
                                        class: 'form-check-input'
                                    }
                                }) }}

                                {{ form_label(registrationForm.agreeTerms, null, {
                                    label_attr: {
                                        class: 'form-check-label'
                                    }
                                }) }}
                            </div>

                            {{ form_errors(registrationForm.agreeTerms) }}
                        </div>

                        <button type="submit"
                                class="btn btn-danger btn-lg w-100 rounded-3">
                            Create Account
                        </button>

                    {{ form_end(registrationForm) }}

                    <hr class="my-4">

                    <p class="text-center text-muted mb-0">
                        Already have an account?
                        <a href="{{ path('app_login') }}"
                           class="text-danger fw-semibold text-decoration-none">
                            Sign in
                        </a>
                    </p>

                </div>
            </div>

            <div class="text-center mt-3 text-muted small">
                Guest users: 5 analyses/day • Members: 10 analyses/day
                <br>
                Membership plans coming soon.
            </div>

        </div>
    </div>
</div>
{% endblock %}